---
---

<section class="countdown-section">
  <div class="countdown-inner">
    <div class="countdown-label reveal">
      <span class="label-line"></span>
      La Compétition Commence Dans
      <span class="label-line"></span>
    </div>

    <div class="countdown-grid reveal" id="countdown">
      <div class="count-block">
        <span class="count-val" id="days">00</span>
        <span class="count-unit">Jours</span>
      </div>
      <span class="count-colon" aria-hidden="true">:</span>
      <div class="count-block">
        <span class="count-val" id="hours">00</span>
        <span class="count-unit">Heures</span>
      </div>
      <span class="count-colon" aria-hidden="true">:</span>
      <div class="count-block">
        <span class="count-val" id="minutes">00</span>
        <span class="count-unit">Minutes</span>
      </div>
      <span class="count-colon" aria-hidden="true">:</span>
      <div class="count-block">
        <span class="count-val" id="seconds">00</span>
        <span class="count-unit">Secondes</span>
      </div>
    </div>

    <p class="countdown-date reveal">📅 29 Avril 2026 — UrbanSoccer Toulouse Sept Deniers</p>
  </div>
</section>

<style>
  .countdown-section {
    background: var(--cream);
    padding: clamp(48px, 8vw, 80px) clamp(16px, 5vw, 40px);
    overflow: hidden;
  }
  .countdown-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .countdown-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(0.6rem, 1.5vw, 0.75rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(4,57,39,0.6);
    margin-bottom: clamp(28px, 5vw, 48px);
    flex-wrap: wrap;
    text-align: center;
  }
  .label-line { flex: 1; max-width: 60px; height: 1px; background: rgba(4,57,39,0.2); }

  .countdown-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
    gap: 0;
    margin-bottom: clamp(20px, 4vw, 32px);
    overflow: hidden;
  }

  .count-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* fluid padding */
    padding: 0 clamp(8px, 2.5vw, 28px);
  }

  .count-val {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    /* fluid font: shrinks on small screens, grows on large */
    font-size: clamp(2.2rem, 8vw, 7rem);
    color: var(--bottle);
    line-height: 1;
    transition: transform 0.2s ease;
    min-width: 2ch;
    text-align: center;
    display: block;
  }

  .count-unit {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.55rem, 1.2vw, 0.7rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(4,57,39,0.5);
    margin-top: 6px;
    white-space: nowrap;
  }

  .count-colon {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.5rem, 5vw, 5rem);
    color: var(--bottle);
    opacity: 0.3;
    margin-bottom: clamp(14px, 2vw, 22px);
    flex-shrink: 0;
    animation: blink 1s ease infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.1; } }

  .countdown-date {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    color: rgba(4,57,39,0.6);
    letter-spacing: 0.05em;
  }

  /* Very small screens: break into 2×2 grid */
  @media (max-width: 400px) {
    .countdown-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: auto auto;
      gap: 0;
      align-items: center;
      justify-items: center;
    }
    /* Hide the 3rd and 4th colons, show only 2 */
    .count-colon:nth-child(4) { display: none; }
    .count-colon:nth-child(6) { display: none; }
    .count-val { font-size: clamp(2rem, 12vw, 3rem); }
  }
</style>

<script>
  const targetDate = new Date('2026-04-29T09:00:00');

  function pad(n: number) { return String(n).padStart(2, '0'); }

  function update() {
    const diff = targetDate.getTime() - Date.now();
    const dEl = document.getElementById('days')!;
    const hEl = document.getElementById('hours')!;
    const mEl = document.getElementById('minutes')!;
    const sEl = document.getElementById('seconds')!;

    if (diff <= 0) {
      [dEl, hEl, mEl, sEl].forEach(el => el.textContent = '00');
      return;
    }

    const days    = Math.floor(diff / 86400000);
    const hours   = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000) / 60000);
    const seconds = Math.floor((diff % 60000) / 1000);

    const animate = (el: HTMLElement, val: string) => {
      if (el.textContent !== val) {
        el.style.transform = 'scale(1.1)';
        el.textContent = val;
        setTimeout(() => el.style.transform = '', 200);
      }
    };

    animate(dEl, pad(days));
    hEl.textContent = pad(hours);
    mEl.textContent = pad(minutes);
    animate(sEl, pad(seconds));
  }

  update();
  setInterval(update, 1000);
</script>
